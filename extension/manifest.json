{
  "manifest_version": 3,
  "name": "Phish-Bit Interceptor",
  "version": "1.0.1",
  "description": "Scans for phishing links and QR codes.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["jsQR.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Phish-Bit Interceptor"
  },
  "options_page": "options.html"
}